<?php
session_start();

require_once "connexion_bdd.php";

header("Content-Type: application/json; charset=utf-8");

mysqli_report(MYSQLI_REPORT_ERROR | MYSQLI_REPORT_STRICT);

try {
    if (!isset($_SESSION["id_utilisateur"])) {
        echo json_encode([
            "succes" => false,
            "message" => "utilisateur non connecte"
        ]);
        exit;
    }

    if ($_SESSION["role"] !== "admin") {
        echo json_encode([
            "succes" => false,
            "message" => "acces refuse"
        ]);
        exit;
    }

    if (!isset($_POST["id_utilisateur"])) {
        echo json_encode([
            "succes" => false,
            "message" => "id utilisateur manquant"
        ]);
        exit;
    }

    $id_utilisateur = intval($_POST["id_utilisateur"]);

    $requete = "
        UPDATE UTILISATEUR
        SET 
            statut_compte = 'actif',
            date_fin_ban = NULL,
            motif_ban = NULL,
            banni_par = NULL
        WHERE id_utilisateur = ?
    ";

    $preparation = mysqli_prepare($connexion, $requete);
    mysqli_stmt_bind_param($preparation, "i", $id_utilisateur);
    mysqli_stmt_execute($preparation);

    echo json_encode([
        "succes" => true,
        "message" => "utilisateur debanni"
    ]);
    exit;

} catch (Throwable $erreur) {
    echo json_encode([
        "succes" => false,
        "message" => "erreur deban : " . $erreur->getMessage()
    ]);
    exit;
}
?>
