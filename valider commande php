<?php
session_start();

require_once "connexion_bdd.php";

header("Content-Type: application/json; charset=utf-8");

mysqli_report(MYSQLI_REPORT_ERROR | MYSQLI_REPORT_STRICT);

$transaction_lancee = false;

try {
    if (!isset($_SESSION["id_utilisateur"])) {
        echo json_encode([
            "succes" => false,
            "message" => "utilisateur non connecte"
        ]);
        exit;
    }

    if ($_SESSION["role"] !== "acheteur") {
        echo json_encode([
            "succes" => false,
            "message" => "seuls les acheteurs peuvent valider une commande"
        ]);
        exit;
    }

    $champs_obligatoires = [
        "prenom",
        "nom",
        "email",
        "telephone",
        "adresse",
        "code_postal",
        "ville",
        "pays",
        "nom_carte",
        "numero_carte",
        "expiration_carte",
        "cvv_carte"
    ];

    foreach ($champs_obligatoires as $champ) {
        if (!isset($_POST[$champ]) || trim($_POST[$champ]) === "") {
            echo json_encode([
                "succes" => false,
                "message" => "champ obligatoire manquant : " . $champ
            ]);
            exit;
        }
    }

    // validation simple du paiement simule
    $numero_carte = preg_replace("/\s+/", "", trim($_POST["numero_carte"]));
    $expiration_carte = trim($_POST["expiration_carte"]);
    $cvv_carte = trim($_POST["cvv_carte"]);

    if (!preg_match("/^[0-9]{16}$/", $numero_carte)) {
        echo json_encode([
            "succes" => false,
            "message" => "numero de carte invalide"
        ]);
        exit;
    }

    if (!preg_match("/^[0-9]{2}\/[0-9]{2}$/", $expiration_carte)) {
        echo json_encode([
            "succes" => false,
            "message" => "date d'expiration invalide"
        ]);
        exit;
    }

    if (!preg_match("/^[0-9]{3}$/", $cvv_carte)) {
        echo json_encode([
            "succes" => false,
            "message" => "cvv invalide"
        ]);
        exit;
    }

    $id_acheteur = intval($_SESSION["id_utilisateur"]);

    // on recupere le panier de l'acheteur
    $requete_lignes = "
        SELECT 
            lp.id_ligne_panier,
            lp.prix_final,
            p.id_panier,
            v.id_voiture,
            v.statut_annonce,
            v.modele,
            v.id_vendeur,
            m.nom_marque
        FROM PANIER p
        INNER JOIN LIGNE_PANIER lp ON p.id_panier = lp.id_panier
        INNER JOIN VOITURE v ON lp.id_voiture = v.id_voiture
        INNER JOIN MARQUE m ON v.id_marque = m.id_marque
        WHERE p.id_utilisateur = ?
    ";

    $preparation_lignes = mysqli_prepare($connexion, $requete_lignes);
    mysqli_stmt_bind_param($preparation_lignes, "i", $id_acheteur);
    mysqli_stmt_execute($preparation_lignes);

    $resultat_lignes = mysqli_stmt_get_result($preparation_lignes);

    $lignes = [];
    $sous_total = 0;

    while ($ligne = mysqli_fetch_assoc($resultat_lignes)) {
        if ($ligne["statut_annonce"] !== "validee") {
            echo json_encode([
                "succes" => false,
                "message" => "une voiture du panier n'est plus disponible"
            ]);
            exit;
        }

        $lignes[] = $ligne;
        $sous_total += floatval($ligne["prix_final"]);
    }

    if (count($lignes) === 0) {
        echo json_encode([
            "succes" => false,
            "message" => "panier vide"
        ]);
        exit;
    }

    // frais realistes pour la simulation
    $taux_frais_mise_relation = 0.10;
    $taux_tva = 0.20;

    $frais_mise_relation = $sous_total * $taux_frais_mise_relation;
    $tva_frais = $frais_mise_relation * $taux_tva;
    $total_ttc = $sous_total + $frais_mise_relation + $tva_frais;

    $premiere_ligne = $lignes[0];

    $id_voiture_commande = intval($premiere_ligne["id_voiture"]);
    $id_vendeur_commande = intval($premiere_ligne["id_vendeur"]);

    mysqli_begin_transaction($connexion);
    $transaction_lancee = true;

    // on cree la commande
    // prix_final = prix des vehicules
    // montant_total = total ttc avec frais
    $requete_commande = "
        INSERT INTO COMMANDE (
            prix_final,
            montant_total,
            mode_transaction,
            statut_commande,
            id_acheteur,
            id_utilisateur,
            id_vendeur,
            id_voiture
        )
        VALUES (?, ?, 'achat_immediat', 'validee', ?, ?, ?, ?)
    ";

    $preparation_commande = mysqli_prepare($connexion, $requete_commande);

    mysqli_stmt_bind_param(
        $preparation_commande,
        "ddiiii",
        $sous_total,
        $total_ttc,
        $id_acheteur,
        $id_acheteur,
        $id_vendeur_commande,
        $id_voiture_commande
    );

    mysqli_stmt_execute($preparation_commande);

    $id_commande = mysqli_insert_id($connexion);

    // on passe les voitures du panier en vendues
    foreach ($lignes as $ligne) {
        $id_voiture = intval($ligne["id_voiture"]);
        $id_vendeur = intval($ligne["id_vendeur"]);

        $requete_update = "
            UPDATE VOITURE
            SET statut_annonce = 'vendue'
            WHERE id_voiture = ?
        ";

        $preparation_update = mysqli_prepare($connexion, $requete_update);
        mysqli_stmt_bind_param($preparation_update, "i", $id_voiture);
        mysqli_stmt_execute($preparation_update);

        // notif vendeur
        $message = "votre vehicule " . $ligne["nom_marque"] . " " . $ligne["modele"] . " a ete vendu via un achat immediat";
        $type_notification = "voiture_vendue";

        $requete_notification = "
            INSERT INTO NOTIFICATION (message, type_notification, lu, id_utilisateur)
            VALUES (?, ?, FALSE, ?)
        ";

        $preparation_notification = mysqli_prepare($connexion, $requete_notification);
        mysqli_stmt_bind_param($preparation_notification, "ssi", $message, $type_notification, $id_vendeur);
        mysqli_stmt_execute($preparation_notification);
    }

    // notification acheteur
    $message_acheteur = "votre commande numero " . $id_commande . " a ete validee. Paiement simule accepte.";
    $type_notification_acheteur = "commande_validee";

    $requete_notification_acheteur = "
        INSERT INTO NOTIFICATION (message, type_notification, lu, id_utilisateur)
        VALUES (?, ?, FALSE, ?)
    ";

    $preparation_notification_acheteur = mysqli_prepare($connexion, $requete_notification_acheteur);
    mysqli_stmt_bind_param(
        $preparation_notification_acheteur,
        "ssi",
        $message_acheteur,
        $type_notification_acheteur,
        $id_acheteur
    );
    mysqli_stmt_execute($preparation_notification_acheteur);

    // on vide le panier
    $requete_vidage = "
        DELETE lp
        FROM LIGNE_PANIER lp
        INNER JOIN PANIER p ON lp.id_panier = p.id_panier
        WHERE p.id_utilisateur = ?
    ";

    $preparation_vidage = mysqli_prepare($connexion, $requete_vidage);
    mysqli_stmt_bind_param($preparation_vidage, "i", $id_acheteur);
    mysqli_stmt_execute($preparation_vidage);

    mysqli_commit($connexion);

    echo json_encode([
        "succes" => true,
        "message" => "commande validee",
        "id_commande" => $id_commande,
        "sous_total" => $sous_total,
        "frais_mise_relation" => $frais_mise_relation,
        "tva_frais" => $tva_frais,
        "total_ttc" => $total_ttc
    ]);
    exit;

} catch (Throwable $erreur) {
    if ($transaction_lancee === true) {
        mysqli_rollback($connexion);
    }

    echo json_encode([
        "succes" => false,
        "message" => "erreur validation commande : " . $erreur->getMessage()
    ]);
    exit;
}
?>
