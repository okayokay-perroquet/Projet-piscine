<?php
session_start();

require_once "connexion_bdd.php";

// reponse en json
header("Content-Type: application/json; charset=utf-8");

// on verifie la connexion
if (!isset($_SESSION["id_utilisateur"])) {
    echo json_encode([
        "succes" => false,
        "message" => "utilisateur non connecte"
    ]);
    exit;
}

// on verifie que c'est bien un vendeur
if ($_SESSION["role"] !== "vendeur") {
    echo json_encode([
        "succes" => false,
        "message" => "acces refuse"
    ]);
    exit;
}

$id_vendeur = $_SESSION["id_utilisateur"];

// on recupere les annonces du vendeur
$requete = "
    SELECT 
        v.id_voiture,
        v.modele,
        v.annee,
        v.kilometrage,
        v.puissance,
        v.prix,
        v.mode_vente,
        v.statut_annonce,
        v.description,
        m.nom_marque,
        i.url_image
    FROM VOITURE v
    INNER JOIN MARQUE m ON v.id_marque = m.id_marque
    LEFT JOIN IMAGE_VOITURE i ON v.id_voiture = i.id_voiture AND i.image_principale = 1
    WHERE v.id_vendeur = ?
    ORDER BY v.date_publication DESC
";

$preparation = mysqli_prepare($connexion, $requete);
mysqli_stmt_bind_param($preparation, "i", $id_vendeur);
mysqli_stmt_execute($preparation);

$resultat = mysqli_stmt_get_result($preparation);

$annonces = [];

while ($ligne = mysqli_fetch_assoc($resultat)) {
    $annonces[] = $ligne;
}

echo json_encode([
    "succes" => true,
    "annonces" => $annonces
]);
?>
