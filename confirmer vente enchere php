
<?php
session_start();

require_once "connexion_bdd.php";

header("Content-Type: application/json; charset=utf-8");

mysqli_report(MYSQLI_REPORT_ERROR | MYSQLI_REPORT_STRICT);

$transaction_lancee = false;

try {
    if (!isset($_SESSION["id_utilisateur"])) {
        echo json_encode([
            "succes" => false,
            "message" => "utilisateur non connecte"
        ]);
        exit;
    }

    if ($_SESSION["role"] !== "admin") {
        echo json_encode([
            "succes" => false,
            "message" => "acces refuse"
        ]);
        exit;
    }

    if (!isset($_POST["id_enchere"])) {
        echo json_encode([
            "succes" => false,
            "message" => "id enchere manquant"
        ]);
        exit;
    }

    $id_enchere = intval($_POST["id_enchere"]);

    $requete_infos = "
        SELECT 
            e.id_enchere,
            e.id_voiture,
            e.id_meilleur_acheteur,
            e.prix_actuel,
            e.statut_enchere,
            v.id_vendeur,
            v.modele,
            m.nom_marque
        FROM ENCHERE e
        INNER JOIN VOITURE v ON e.id_voiture = v.id_voiture
        INNER JOIN MARQUE m ON v.id_marque = m.id_marque
        WHERE e.id_enchere = ?
        LIMIT 1
    ";

    $preparation_infos = mysqli_prepare($connexion, $requete_infos);
    mysqli_stmt_bind_param($preparation_infos, "i", $id_enchere);
    mysqli_stmt_execute($preparation_infos);

    $resultat_infos = mysqli_stmt_get_result($preparation_infos);

    if (mysqli_num_rows($resultat_infos) === 0) {
        echo json_encode([
            "succes" => false,
            "message" => "enchere introuvable"
        ]);
        exit;
    }

    $enchere = mysqli_fetch_assoc($resultat_infos);

    if ($enchere["statut_enchere"] !== "terminee") {
        echo json_encode([
            "succes" => false,
            "message" => "cette enchere n'est pas encore terminee"
        ]);
        exit;
    }

    if ($enchere["id_meilleur_acheteur"] === null) {
        echo json_encode([
            "succes" => false,
            "message" => "aucun acheteur gagnant"
        ]);
        exit;
    }

    mysqli_begin_transaction($connexion);
    $transaction_lancee = true;

    // on confirme l'enchere
    $requete_update_enchere = "
        UPDATE ENCHERE
        SET statut_enchere = 'confirmee'
        WHERE id_enchere = ?
    ";

    $preparation_update_enchere = mysqli_prepare($connexion, $requete_update_enchere);
    mysqli_stmt_bind_param($preparation_update_enchere, "i", $id_enchere);
    mysqli_stmt_execute($preparation_update_enchere);

    // on met la voiture en vendue
    $requete_update_voiture = "
        UPDATE VOITURE
        SET statut_annonce = 'vendue'
        WHERE id_voiture = ?
    ";

    $preparation_update_voiture = mysqli_prepare($connexion, $requete_update_voiture);
    mysqli_stmt_bind_param($preparation_update_voiture, "i", $enchere["id_voiture"]);
    mysqli_stmt_execute($preparation_update_voiture);

    // notification acheteur gagnant
    $prix_formate = number_format(floatval($enchere["prix_actuel"]), 0, ",", " ");

    $message_acheteur = "l'admin a confirme votre achat de " . $enchere["nom_marque"] . " " . $enchere["modele"] . " pour " . $prix_formate . " euros. Le vehicule est maintenant vendu.";
    $type_acheteur = "enchere_gagnee";

    $requete_notif_acheteur = "
        INSERT INTO NOTIFICATION (message, type_notification, lu, id_utilisateur)
        VALUES (?, ?, FALSE, ?)
    ";

    $preparation_notif_acheteur = mysqli_prepare($connexion, $requete_notif_acheteur);
    mysqli_stmt_bind_param(
        $preparation_notif_acheteur,
        "ssi",
        $message_acheteur,
        $type_acheteur,
        $enchere["id_meilleur_acheteur"]
    );
    mysqli_stmt_execute($preparation_notif_acheteur);

    // notification vendeur
    $message_vendeur = "l'admin a confirme la vente aux encheres de " . $enchere["nom_marque"] . " " . $enchere["modele"] . " pour " . $prix_formate . " euros.";
    $type_vendeur = "vente_enchere_confirmee";

    $requete_notif_vendeur = "
        INSERT INTO NOTIFICATION (message, type_notification, lu, id_utilisateur)
        VALUES (?, ?, FALSE, ?)
    ";

    $preparation_notif_vendeur = mysqli_prepare($connexion, $requete_notif_vendeur);
    mysqli_stmt_bind_param(
        $preparation_notif_vendeur,
        "ssi",
        $message_vendeur,
        $type_vendeur,
        $enchere["id_vendeur"]
    );
    mysqli_stmt_execute($preparation_notif_vendeur);

    mysqli_commit($connexion);

    echo json_encode([
        "succes" => true,
        "message" => "vente enchere confirmee"
    ]);
    exit;

} catch (Throwable $erreur) {
    if ($transaction_lancee === true) {
        mysqli_rollback($connexion);
    }

    echo json_encode([
        "succes" => false,
        "message" => "erreur confirmation enchere : " . $erreur->getMessage()
    ]);
    exit;
}
?>
