<?php
session_start();

require_once "connexion_bdd.php";

header("Content-Type: application/json; charset=utf-8");

mysqli_report(MYSQLI_REPORT_ERROR | MYSQLI_REPORT_STRICT);

try {
    if (!isset($_SESSION["id_utilisateur"])) {
        echo json_encode([
            "succes" => false,
            "message" => "utilisateur non connecte"
        ]);
        exit;
    }

    if ($_SESSION["role"] !== "admin") {
        echo json_encode([
            "succes" => false,
            "message" => "acces refuse"
        ]);
        exit;
    }

    $requete = "
        SELECT 
            u.id_utilisateur,
            u.nom,
            u.prenom,
            u.email,
            u.statut_compte,
            u.date_fin_ban,
            u.motif_ban,
            r.nom_role,
            admin.nom AS nom_admin,
            admin.prenom AS prenom_admin
        FROM UTILISATEUR u
        INNER JOIN ROLE r ON u.id_role = r.id_role
        LEFT JOIN UTILISATEUR admin ON u.banni_par = admin.id_utilisateur
        WHERE r.nom_role IN ('acheteur', 'vendeur')
        ORDER BY r.nom_role ASC, u.nom ASC
    ";

    $resultat = mysqli_query($connexion, $requete);

    $utilisateurs = [];

    while ($utilisateur = mysqli_fetch_assoc($resultat)) {
        $utilisateurs[] = $utilisateur;
    }

    echo json_encode([
        "succes" => true,
        "utilisateurs" => $utilisateurs
    ]);
    exit;

} catch (Throwable $erreur) {
    echo json_encode([
        "succes" => false,
        "message" => "erreur utilisateurs : " . $erreur->getMessage()
    ]);
    exit;
}
?>
