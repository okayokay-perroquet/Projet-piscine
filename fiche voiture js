// on garde la voiture actuelle pour les actions
let voitureActuelle = null;
let intervalleMinuteurEnchere = null;

// galerie images
let imagesVoiture = [];
let indexImageActuelle = 0;

// on attend que la page soit chargee
document.addEventListener("DOMContentLoaded", function() {
    chargerVoiture();
});

// on recupere l'id dans l'url
function recupererIdVoiture() {
    const parametres = new URLSearchParams(window.location.search);
    return parametres.get("id");
}

// on corrige les chemins d'images si besoin
function corrigerCheminImage(chemin) {
    if (!chemin || chemin.trim() === "") {
        return "images/voitures/ferrari_488.png";
    }

    let cheminCorrige = chemin.trim();

    if (cheminCorrige.startsWith("../frontend/")) {
        cheminCorrige = cheminCorrige.replace("../frontend/", "");
    }

    if (cheminCorrige.startsWith("frontend/")) {
        cheminCorrige = cheminCorrige.replace("frontend/", "");
    }

    if (cheminCorrige.startsWith("/frontend/")) {
        cheminCorrige = cheminCorrige.replace("/frontend/", "");
    }

    return cheminCorrige;
}

// on charge la voiture depuis php
function chargerVoiture() {
    const idVoiture = recupererIdVoiture();
    const zoneFiche = document.getElementById("zoneFicheVoiture");

    if (!idVoiture) {
        zoneFiche.innerHTML = `
            <div class="message-fiche">
                <h1>aucun véhicule sélectionné</h1>
                <p>retournez au catalogue pour choisir une voiture</p>
                <a href="catalogue.html" class="bouton bouton-principal">Retour au catalogue</a>
            </div>
        `;
        return;
    }

    fetch("../backend/afficher_detail_voiture.php?id=" + idVoiture)
        .then(function(reponse) {
            return reponse.json();
        })
        .then(function(donnees) {
            if (donnees.succes === true) {
                voitureActuelle = donnees.voiture;

                // compatible avec plusieurs formats possibles du backend
                if (donnees.images) {
                    voitureActuelle.images = donnees.images;
                }

                afficherFicheVoiture(voitureActuelle);

                if (voitureActuelle.mode_vente === "enchere") {
                    chargerEnchereVoiture(voitureActuelle.id_voiture);
                }
            } else {
                afficherErreurFiche();
            }
        })
        .catch(function() {
            afficherErreurFiche();
        });
}

