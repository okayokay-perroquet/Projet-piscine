// on prepare les images de la galerie
function initialiserGalerieVoiture(voiture) {
    imagesVoiture = [];

    if (voiture.images && Array.isArray(voiture.images) && voiture.images.length > 0) {
        voiture.images.forEach(function(image) {
            imagesVoiture.push({
                url_image: corrigerCheminImage(image.url_image),
                image_principale: image.image_principale
            });
        });
    } else if (voiture.url_image) {
        imagesVoiture.push({
            url_image: corrigerCheminImage(voiture.url_image),
            image_principale: 1
        });
    }

    if (imagesVoiture.length === 0) {
        imagesVoiture.push({
            url_image: "images/voitures/ferrari_488.png",
            image_principale: 1
        });
    }

    const indexPrincipale = imagesVoiture.findIndex(function(image) {
        return Number(image.image_principale) === 1;
    });

    if (indexPrincipale >= 0) {
        indexImageActuelle = indexPrincipale;
    } else {
        indexImageActuelle = 0;
    }

    afficherImageGalerie();
    afficherMiniaturesGalerie();
    gererAffichageBoutonsGalerie();
}

// on affiche la grande image
function afficherImageGalerie() {
    const imagePrincipale = document.getElementById("imagePrincipaleGalerie");
    const compteur = document.getElementById("compteurGalerie");

    if (!imagePrincipale || imagesVoiture.length === 0) {
        return;
    }

    imagePrincipale.src = imagesVoiture[indexImageActuelle].url_image;

    if (voitureActuelle) {
        imagePrincipale.alt = voitureActuelle.nom_marque + " " + voitureActuelle.modele;
    }

    if (compteur) {
        compteur.textContent = (indexImageActuelle + 1) + " / " + imagesVoiture.length;
    }

    mettreMiniatureActive();
}

// on affiche les miniatures
function afficherMiniaturesGalerie() {
    const zoneMiniatures = document.getElementById("listeMiniaturesGalerie");

    if (!zoneMiniatures) {
        return;
    }

    zoneMiniatures.innerHTML = "";

    imagesVoiture.forEach(function(image, index) {
        const miniature = document.createElement("button");
        miniature.type = "button";
        miniature.className = "miniature-galerie";

        if (index === indexImageActuelle) {
            miniature.classList.add("active");
        }

        miniature.innerHTML = `
            <img src="${image.url_image}" alt="image ${index + 1}">
        `;

        miniature.addEventListener("click", function() {
            indexImageActuelle = index;
            afficherImageGalerie();
        });

        zoneMiniatures.appendChild(miniature);
    });
}

// active la bonne miniature
function mettreMiniatureActive() {
    const miniatures = document.querySelectorAll(".miniature-galerie");

    miniatures.forEach(function(miniature, index) {
        if (index === indexImageActuelle) {
            miniature.classList.add("active");
        } else {
            miniature.classList.remove("active");
        }
    });
}

// image suivante
function imageSuivanteGalerie() {
    if (imagesVoiture.length <= 1) {
        return;
    }

    indexImageActuelle++;

    if (indexImageActuelle >= imagesVoiture.length) {
        indexImageActuelle = 0;
    }

    afficherImageGalerie();
}

// image precedente
function imagePrecedenteGalerie() {
    if (imagesVoiture.length <= 1) {
        return;
    }

    indexImageActuelle--;

    if (indexImageActuelle < 0) {
        indexImageActuelle = imagesVoiture.length - 1;
    }

    afficherImageGalerie();
}

// scroll miniatures gauche
function scrollerMiniaturesGauche() {
    const zone = document.getElementById("listeMiniaturesGalerie");

    if (!zone) {
        return;
    }

    zone.scrollBy({
        left: -250,
        behavior: "smooth"
    });
}

// scroll miniatures droite
function scrollerMiniaturesDroite() {
    const zone = document.getElementById("listeMiniaturesGalerie");

    if (!zone) {
        return;
    }

    zone.scrollBy({
        left: 250,
        behavior: "smooth"
    });
}

// cache les boutons si une seule image
function gererAffichageBoutonsGalerie() {
    const boutons = document.querySelectorAll(".bouton-galerie, .bouton-scroll-miniatures");

    if (imagesVoiture.length <= 1) {
        boutons.forEach(function(bouton) {
            bouton.style.display = "none";
        });
    } else {
        boutons.forEach(function(bouton) {
            bouton.style.display = "flex";
        });
    }
}

// bouton selon le mode et le statut
function genererBoutonAction(voiture) {
    if (voiture.statut_annonce === "vendue") {
        return `<button class="bouton bouton-vendu" disabled>Véhicule vendu</button>`;
    }

    if (voiture.mode_vente === "achat_immediat") {
        return `<a href="../backend/ajouter_panier.php?id=${voiture.id_voiture}" class="bouton bouton-principal">Acheter maintenant</a>`;
    }

    if (voiture.mode_vente === "enchere") {
        return `<button class="bouton bouton-principal" onclick="descendreVersEnchere()">Participer à l’enchère</button>`;
    }

    if (voiture.mode_vente === "negociation") {
        return `<button class="bouton bouton-principal" onclick="ouvrirFormulaireNegociation()">Proposer une offre</button>`;
    }

    return `<a href="catalogue.html" class="bouton bouton-principal">Voir le catalogue</a>`;
}

// descendre vers le bloc enchere
function descendreVersEnchere() {
    const zone = document.getElementById("zoneEnchereFiche");

    if (zone) {
        zone.scrollIntoView({
            behavior: "smooth",
            block: "center"
        });
    }
}

// on charge l'enchere de la voiture
function chargerEnchereVoiture(idVoiture) {
    fetch("../backend/afficher_enchere_voiture.php?id_voiture=" + idVoiture)
        .then(function(reponse) {
            return reponse.json();
        })
        .then(function(donnees) {
            if (donnees.succes === true) {
                afficherBlocEnchere(donnees.enchere, donnees.temps_restant_secondes);
            } else {
                afficherBlocEnchereIntrouvable();
            }
        })
        .catch(function() {
            afficherBlocEnchereIntrouvable();
        });
}

