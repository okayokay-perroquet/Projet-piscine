    if (!zone) {
        return;
    }

    const prixDepart = Number(enchere.prix_depart).toLocaleString("fr-FR");
    const prixActuel = Number(enchere.prix_actuel).toLocaleString("fr-FR");

    let meilleurAcheteur = "aucune offre pour le moment";

    if (enchere.prenom_meilleur && enchere.nom_meilleur) {
        meilleurAcheteur = enchere.prenom_meilleur + " " + enchere.nom_meilleur;
    }

    let contenuAction = "";

    if (voitureActuelle.statut_annonce === "vendue") {
        contenuAction = `
            <div class="message-enchere-terminee">
                véhicule vendu
            </div>
        `;
    } else if (enchere.statut_enchere === "active" && tempsRestantSecondes > 0) {
        contenuAction = `
            <div class="formulaire-enchere-fiche">
                <label for="montantOffreEnchere">Votre offre</label>
                <input type="number" id="montantOffreEnchere" placeholder="montant supérieur au prix actuel">

                <button class="bouton bouton-principal" onclick="envoyerOffreEnchere(${enchere.id_voiture})">
                    Envoyer mon offre
                </button>
            </div>
        `;
    } else if (enchere.statut_enchere === "terminee") {
        contenuAction = `
            <div class="message-enchere-terminee">
                enchère terminée, en attente de confirmation par l’admin
            </div>
        `;
    } else if (enchere.statut_enchere === "confirmee") {
        contenuAction = `
            <div class="message-enchere-terminee">
                vente confirmée par l’admin
            </div>
        `;
    }

    zone.innerHTML = `
        <div class="bloc-enchere-fiche">
            <div class="haut-enchere-fiche">
                <div>
                    <p class="petit-titre">vente aux enchères</p>
                    <h2>Enchère en cours</h2>
                </div>

                <span class="badge-enchere ${classeStatutEnchere(enchere.statut_enchere)}">
                    ${formaterStatutEnchere(enchere.statut_enchere)}
                </span>
            </div>

            <div class="grille-enchere-fiche">
                <div>
                    <span>Prix de départ</span>
                    <strong>${prixDepart} €</strong>
                </div>

                <div>
                    <span>Prix actuel</span>
                    <strong>${prixActuel} €</strong>
                </div>

                <div>
                    <span>Meilleur enchérisseur</span>
                    <strong>${meilleurAcheteur}</strong>
                </div>

                <div>
                    <span>Temps restant</span>
                    <strong id="minuteurEnchere">chargement...</strong>
                </div>
            </div>

            ${contenuAction}

            <p class="info-enchere">
                Si une offre est envoyée alors qu’il reste moins d’une minute, le compteur est automatiquement remis à 1 minute.
            </p>

            <div id="messageEnchere"></div>
        </div>
    `;

    lancerMinuteurEnchere(tempsRestantSecondes, enchere.id_voiture);
}

// on lance le minuteur
function lancerMinuteurEnchere(tempsRestantSecondes, idVoiture) {
    const zoneMinuteur = document.getElementById("minuteurEnchere");

    if (!zoneMinuteur) {
        return;
    }

    if (intervalleMinuteurEnchere !== null) {
        clearInterval(intervalleMinuteurEnchere);
    }

    let secondes = tempsRestantSecondes;

    afficherTempsRestant(secondes);

    intervalleMinuteurEnchere = setInterval(function() {
        secondes--;

        if (secondes <= 0) {
            clearInterval(intervalleMinuteurEnchere);
            intervalleMinuteurEnchere = null;

            afficherTempsRestant(0);

            // on recharge pour passer l'enchere en terminee cote backend
            chargerEnchereVoiture(idVoiture);
            return;
        }

        afficherTempsRestant(secondes);
    }, 1000);
}

// on affiche temps propre
function afficherTempsRestant(secondes) {
    const zoneMinuteur = document.getElementById("minuteurEnchere");

    if (!zoneMinuteur) {
        return;
    }

    const jours = Math.floor(secondes / 86400);
    const heures = Math.floor((secondes % 86400) / 3600);
    const minutes = Math.floor((secondes % 3600) / 60);
    const secondesRestantes = secondes % 60;

    let texte = "";

    if (jours > 0) {
        texte += jours + "j ";
    }

    if (heures > 0 || jours > 0) {
        texte += heures + "h ";
    }

    texte += minutes + "m " + secondesRestantes + "s";

    zoneMinuteur.textContent = texte;
}

// envoyer une offre enchere
function envoyerOffreEnchere(idVoiture) {
    const champMontant = document.getElementById("montantOffreEnchere");
    const zoneMessage = document.getElementById("messageEnchere");

    if (!champMontant) {
        return;
    }

    const montant = champMontant.value;

    if (montant === "" || Number(montant) <= 0) {
        alert("entrez un montant valide");
        return;
    }

    const donnees = new FormData();
    donnees.append("id_voiture", idVoiture);
    donnees.append("montant_offre", montant);

    fetch("../backend/proposer_enchere.php", {
        method: "POST",
        body: donnees
    })
        .then(function(reponse) {
            return reponse.json();
        })
        .then(function(resultat) {
            if (resultat.succes === true) {
                if (zoneMessage) {
                    zoneMessage.innerHTML = `
                        <div class="message-enchere-ok">
                            votre offre a bien été envoyée
                        </div>
                    `;
                }

                chargerEnchereVoiture(idVoiture);
            } else {
                alert(resultat.message);
            }
        })
        .catch(function() {
            alert("erreur lors de l’envoi de l’offre");
        });
}

// si aucune enchere trouvee
function afficherBlocEnchereIntrouvable() {
    const zone = document.getElementById("zoneEnchereFiche");

    if (!zone) {
        return;
    }

    zone.innerHTML = `
        <div class="bloc-enchere-fiche">
            <h2>Enchère pas encore active</h2>
            <p class="info-enchere">
                L’enchère sera disponible après validation de l’annonce par l’admin.
            </p>
        </div>
    `;
}

// classe statut enchere
function classeStatutEnchere(statut) {
    if (statut === "active") {
        return "enchere-active";
    }

    if (statut === "terminee") {
        return "enchere-terminee";
    }

    if (statut === "confirmee") {
        return "enchere-confirmee";
    }

    return "enchere-terminee";
}

// texte statut enchere
function formaterStatutEnchere(statut) {
    if (statut === "active") {
        return "active";
    }

    if (statut === "terminee") {
        return "terminée";
    }

    if (statut === "confirmee") {
        return "confirmée";
    }

    return statut;
}

// on affiche le formulaire de negociation
function ouvrirFormulaireNegociation() {
    const zone = document.getElementById("zoneNegociationFiche");

    zone.innerHTML = `
        <div class="formulaire-negociation-fiche">
            <h2>Proposer une offre</h2>

            <label for="prixPropose">Votre prix proposé</label>
            <input type="number" id="prixPropose" placeholder="ex : 210000">

            <label for="messageAcheteur">Message au vendeur</label>
            <textarea id="messageAcheteur" rows="4" placeholder="expliquez rapidement votre proposition"></textarea>

            <button class="bouton bouton-principal" onclick="envoyerNegociation()">
                Envoyer l’offre
            </button>
        </div>
    `;
}

// on envoie la negociation
function envoyerNegociation() {
    const prixPropose = document.getElementById("prixPropose").value;
    const messageAcheteur = document.getElementById("messageAcheteur").value;

    if (prixPropose === "" || Number(prixPropose) <= 0) {
        alert("entrez un prix valide");
        return;
    }

    const donnees = new FormData();
    donnees.append("id_voiture", voitureActuelle.id_voiture);
    donnees.append("prix_propose", prixPropose);
    donnees.append("message_acheteur", messageAcheteur);

    fetch("../backend/proposer_negociation.php", {
        method: "POST",
        body: donnees
    })
        .then(function(reponse) {
            return reponse.json();
        })
        .then(function(resultat) {
            if (resultat.succes === true) {
                document.getElementById("zoneNegociationFiche").innerHTML = `
                    <div class="message-negociation-ok">
                        votre offre a bien été envoyée au vendeur
                    </div>
                `;
            } else {
                alert(resultat.message);
            }
        })
        .catch(function() {
            alert("erreur lors de l’envoi de la négociation");
        });
}

// affichage mode vente
function formaterModeVente(voiture) {
    if (voiture.statut_annonce === "vendue") {
        return "véhicule vendu";
    }

    if (voiture.mode_vente === "achat_immediat") {
        return "achat immédiat";
    }

    if (voiture.mode_vente === "enchere") {
        return "vente aux enchères";
    }

    if (voiture.mode_vente === "negociation") {
        return "prix négociable";
    }

    return voiture.mode_vente;
}

