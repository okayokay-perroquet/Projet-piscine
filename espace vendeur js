// on attend que la page soit chargee
document.addEventListener("DOMContentLoaded", function() {
    verifierSessionVendeur();
    gererMarquePersonnalisee();
    gererPreviewImagesUpload();
    afficherMessageRetour();
    gererChampDureeEnchere();
    chargerMesAnnonces();
    chargerNotifications();
    chargerNegociationsVendeur();
});

// on affiche ou cache le champ duree enchere
function gererChampDureeEnchere() {
    const selectModeVente = document.getElementById("mode_vente");
    const blocDureeEnchere = document.getElementById("blocDureeEnchere");

    if (!selectModeVente || !blocDureeEnchere) {
        return;
    }

    afficherChampDureeEnchere();

    selectModeVente.addEventListener("change", function() {
        afficherChampDureeEnchere();
    });
}

// on affiche le champ seulement si enchere
function afficherChampDureeEnchere() {
    const selectModeVente = document.getElementById("mode_vente");
    const blocDureeEnchere = document.getElementById("blocDureeEnchere");

    if (!selectModeVente || !blocDureeEnchere) {
        return;
    }

    if (selectModeVente.value === "enchere") {
        blocDureeEnchere.style.display = "grid";
    } else {
        blocDureeEnchere.style.display = "none";
    }
}

// on verifie la session du vendeur
function verifierSessionVendeur() {
    fetch("../backend/session_utilisateur.php")
        .then(function(reponse) {
            return reponse.json();
        })
        .then(function(donnees) {
            if (donnees.connecte === true) {
                afficherVendeur(donnees.utilisateur);
            } else {
                afficherNonConnecte();
            }
        })
        .catch(function() {
            afficherNonConnecte();
        });
}

// on affiche le profil vendeur
function afficherVendeur(utilisateur) {
    const carteProfil = document.getElementById("carteProfilVendeur");

    if (!carteProfil) {
        return;
    }

    carteProfil.innerHTML = `
        <h2>Mon profil</h2>
        <p><strong>Nom :</strong> ${utilisateur.prenom} ${utilisateur.nom}</p>
        <p><strong>Email :</strong> ${utilisateur.email}</p>
        <p><strong>Rôle :</strong> ${utilisateur.role}</p>
    `;

    if (utilisateur.role !== "vendeur") {
        carteProfil.innerHTML += `
            <p class="message-erreur">cet espace est prévu pour les vendeurs</p>
        `;
    }
}

// si personne n'est connecte
function afficherNonConnecte() {
    document.querySelector(".page-vendeur").innerHTML = `
        <div class="intro-formulaire-vendeur">
            <h1>Vous n’êtes pas connecté</h1>
            <p>Connectez-vous avec un compte vendeur pour publier une annonce.</p>
            <a href="connexion.html" class="bouton bouton-principal">Se connecter</a>
        </div>
    `;
}

// message apres ajout annonce
function afficherMessageRetour() {
    const parametres = new URLSearchParams(window.location.search);
    const messageRetour = document.getElementById("messageRetour");

    if (!messageRetour) {
        return;
    }

    if (parametres.get("ajout") === "ok") {
        messageRetour.innerHTML = `
            <div class="message-succes">
                annonce ajoutée avec succès, elle est maintenant en attente de validation
            </div>
        `;
    }

    if (parametres.get("ajout") === "erreur") {
        const details = parametres.get("details");

        messageRetour.innerHTML = `
            <div class="message-erreur">
                erreur lors de l’ajout de l’annonce
                ${details ? `<br><small>${details}</small>` : ""}
            </div>
        `;
    }
}

// on charge les annonces du vendeur
function chargerMesAnnonces() {
    fetch("../backend/afficher_mes_annonces.php")
        .then(function(reponse) {
            return reponse.json();
        })
        .then(function(donnees) {
            if (donnees.succes === true) {
                afficherMesAnnonces(donnees.annonces);
            } else {
                afficherErreurAnnonces();
            }
        })
        .catch(function() {
            afficherErreurAnnonces();
        });
}

// on affiche les annonces du vendeur
function afficherMesAnnonces(annonces) {
    const zone = document.getElementById("listeMesAnnonces");
    const compteur = document.getElementById("nombreMesAnnonces");

    if (!zone || !compteur) {
        return;
    }

    zone.innerHTML = "";
    compteur.textContent = annonces.length + " annonce(s)";

    if (annonces.length === 0) {
        zone.innerHTML = `
            <p class="message-vide-vendeur">vous n’avez encore publié aucune annonce</p>
        `;
        return;
    }

    annonces.forEach(function(annonce) {
        const prixFormate = Number(annonce.prix).toLocaleString("fr-FR");
        const kilometrageFormate = Number(annonce.kilometrage).toLocaleString("fr-FR");

        zone.innerHTML += `
            <article class="carte-annonce-vendeur">
                <img src="${annonce.url_image}" alt="${annonce.nom_marque} ${annonce.modele}">

                <div class="contenu-annonce-vendeur">
                    <div class="ligne-haut-annonce">
                        <span class="badge-statut ${classeStatut(annonce.statut_annonce)}">
                            ${formaterStatut(annonce.statut_annonce)}
                        </span>

                        <span>${formaterModeVente(annonce.mode_vente)}</span>
                    </div>

                    <h3>${annonce.nom_marque} ${annonce.modele}</h3>

                    <p>${annonce.annee} • ${kilometrageFormate} km • ${annonce.puissance} ch</p>

                    <strong>${prixFormate} €</strong>

                    <div class="actions-annonce-vendeur">
                        <a href="fiche_voiture.html?id=${annonce.id_voiture}">Voir</a>
                        <button onclick="supprimerAnnonce(${annonce.id_voiture})">Supprimer</button>
                    </div>
                </div>
            </article>
        `;
    });
}

// on supprime une annonce vendeur
function supprimerAnnonce(idVoiture) {
    if (!confirm("supprimer cette annonce ?")) {
        return;
    }

    const donnees = new FormData();
    donnees.append("id_voiture", idVoiture);

    fetch("../backend/supprimer_annonce_vendeur.php", {
        method: "POST",
        body: donnees
    })
        .then(function(reponse) {
            return reponse.json();
        })
        .then(function(resultat) {
            if (resultat.succes === true) {
                chargerMesAnnonces();
                chargerNotifications();
            } else {
                alert(resultat.message || "erreur lors de la suppression");
            }
        })
        .catch(function() {
            alert("erreur lors de la suppression");
        });
}

// on charge les notifications du vendeur
function chargerNotifications() {
    fetch("../backend/afficher_notifications_utilisateur.php")
        .then(function(reponse) {
            return reponse.json();
        })
        .then(function(donnees) {
            if (donnees.succes === true) {
                afficherNotifications(donnees.notifications);
            } else {
                afficherErreurNotifications();
            }
        })
        .catch(function() {
            afficherErreurNotifications();
        });
}

// on affiche les notifications avec etat lu / non lu
function afficherNotifications(notifications) {
    const zone = document.getElementById("listeNotifications");

    if (!zone) {
        return;
    }

    zone.innerHTML = "";

    if (notifications.length === 0) {
        zone.innerHTML = `
            <p class="message-vide-vendeur">aucune notification pour le moment</p>
        `;
        return;
    }

    const notificationsNonLues = notifications.filter(function(notification) {
        return Number(notification.lu) === 0;
    });

    zone.innerHTML += `
        <div class="resume-notifications">
            <strong>${notificationsNonLues.length}</strong> notification(s) non lue(s)
        </div>
    `;

    notifications.forEach(function(notification) {
        const estLue = Number(notification.lu) === 1;

        let classeNotification = "notification-vendeur notification-non-lue";
        let texteBouton = "Marquer comme lu";
        let nouvelEtat = 1;

        if (estLue) {
            classeNotification = "notification-vendeur notification-lue";
            texteBouton = "Marquer comme non lu";
            nouvelEtat = 0;
        }

        zone.innerHTML += `
            <div class="${classeNotification}">
                <div class="haut-notification">
                    <strong>${formaterTypeNotification(notification.type_notification)}</strong>

                    <span class="badge-notification ${estLue ? "badge-lue" : "badge-non-lue"}">
                        ${estLue ? "lue" : "non lue"}
                    </span>
                </div>

                <p>${notification.message}</p>

                <div class="bas-notification">
                    <span>${notification.date_notification}</span>

                    <button onclick="modifierEtatNotification(${notification.id_notification}, ${nouvelEtat})">
                        ${texteBouton}
                    </button>
                </div>
            </div>
        `;
    });
}

// modifier notification vendeur
function modifierEtatNotification(idNotification, nouvelEtat) {
    const donnees = new FormData();
    donnees.append("id_notification", idNotification);
    donnees.append("lu", nouvelEtat);

    fetch("../backend/modifier_etat_notification.php", {
        method: "POST",
        body: donnees
    })
        .then(function(reponse) {
            return reponse.json();
        })
        .then(function(resultat) {
            if (resultat.succes === true) {
                chargerNotifications();
            } else {
                alert(resultat.message);
            }
        })
        .catch(function() {
            alert("erreur lors de la modification de la notification");
        });
}

