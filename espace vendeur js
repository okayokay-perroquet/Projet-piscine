}

// classe couleur du statut
function classeStatut(statut) {
    if (statut === "validee") {
        return "statut-validee";
    }

    if (statut === "vendue") {
        return "statut-refusee";
    }

    if (statut === "refusee") {
        return "statut-refusee";
    }

    return "statut-attente";
}

// texte propre du statut
function formaterStatut(statut) {
    if (statut === "validee") {
        return "validée";
    }

    if (statut === "refusee") {
        return "refusée";
    }

    if (statut === "vendue") {
        return "vendue";
    }

    if (statut === "en_attente") {
        return "en attente";
    }

    return statut;
}

// affichage propre du mode de vente
function formaterModeVente(mode) {
    if (mode === "achat_immediat") {
        return "achat immédiat";
    }

    if (mode === "enchere") {
        return "enchère";
    }

    if (mode === "negociation") {
        return "négociation";
    }

    return mode;
}

// affichage propre des notifications
function formaterTypeNotification(type) {
    if (type === "annonce_validee") {
        return "annonce validée";
    }

    if (type === "annonce_refusee") {
        return "annonce refusée";
    }

    if (type === "annonce_a_valider") {
        return "annonce à valider";
    }

    if (type === "annonce_supprimee") {
        return "annonce supprimée";
    }

    if (type === "voiture_vendue") {
        return "voiture vendue";
    }

    if (type === "negociation_recue") {
        return "négociation reçue";
    }

    if (type === "negociation_mise_a_jour") {
        return "négociation mise à jour";
    }

    if (type === "negociation_acceptee") {
        return "négociation acceptée";
    }

    if (type === "enchere_recue") {
        return "enchère reçue";
    }

    if (type === "enchere_depassee") {
        return "enchère dépassée";
    }

    if (type === "enchere_expiree") {
        return "enchère expirée";
    }

    if (type === "enchere_gagnee") {
        return "enchère gagnée";
    }

    if (type === "vente_enchere_confirmee") {
        return "vente enchère confirmée";
    }

    return type;
}

// chargement des negociations vendeur
function chargerNegociationsVendeur() {
    fetch("../backend/afficher_negociations_vendeur.php")
        .then(function(reponse) {
            return reponse.json();
        })
        .then(function(donnees) {
            if (donnees.succes === true) {
                afficherNegociationsVendeur(donnees.negociations);
            }
        })
        .catch(function() {
            const zone = document.getElementById("listeNegociationsVendeur");

            if (zone) {
                zone.innerHTML =
                    "<p class='message-vide-vendeur'>impossible de charger les négociations</p>";
            }
        });
}

// affichage des negociations vendeur
function afficherNegociationsVendeur(negociations) {
    const zone = document.getElementById("listeNegociationsVendeur");
    const compteur = document.getElementById("nombreNegociationsVendeur");

    if (!zone || !compteur) {
        return;
    }

    zone.innerHTML = "";
    compteur.textContent = negociations.length + " négociation(s)";

    if (negociations.length === 0) {
        zone.innerHTML = `
            <p class="message-vide-vendeur">aucune négociation reçue pour le moment</p>
        `;
        return;
    }

    negociations.forEach(function(negociation) {
        const prixPropose = Number(negociation.prix_propose).toLocaleString("fr-FR");
        const prixInitial = Number(negociation.prix).toLocaleString("fr-FR");

        zone.innerHTML += `
            <article class="carte-negociation-vendeur">
                <img src="${negociation.url_image}" alt="${negociation.nom_marque} ${negociation.modele}">

                <div class="contenu-negociation-vendeur">
                    <span class="badge-negociation ${classeStatutNegociationVendeur(negociation.statut_negociation)}">
                        ${formaterStatutNegociationVendeur(negociation.statut_negociation)}
                    </span>

                    <h3>${negociation.nom_marque} ${negociation.modele}</h3>

                    <p>Prix affiché : ${prixInitial} €</p>
                    <p>Offre reçue : <strong>${prixPropose} €</strong></p>
                    <p>Acheteur : ${negociation.prenom_acheteur} ${negociation.nom_acheteur}</p>

                    ${negociation.message_acheteur ? `<p>Message : ${negociation.message_acheteur}</p>` : ""}
                    ${negociation.reponse_vendeur ? `<p>Votre réponse : ${negociation.reponse_vendeur}</p>` : ""}

                    ${genererActionsNegociationVendeur(negociation)}
                </div>
            </article>
        `;
    });
}

// boutons negociation vendeur
function genererActionsNegociationVendeur(negociation) {
    if (negociation.statut_negociation !== "en_attente") {
        return "";
    }

    return `
        <div class="actions-negociation-vendeur">
            <button class="bouton-accepter-negociation" onclick="repondreNegociation(${negociation.id_negociation}, 'accepter')">
                Accepter
            </button>

            <button class="bouton-refuser-negociation" onclick="repondreNegociation(${negociation.id_negociation}, 'refuser')">
                Refuser
            </button>

            <button class="bouton-contre-negociation" onclick="contreProposerNegociation(${negociation.id_negociation})">
                Contre-proposer
            </button>
        </div>
    `;
}

// reponse vendeur a une negociation
function repondreNegociation(idNegociation, action) {
    const donnees = new FormData();
    donnees.append("id_negociation", idNegociation);
    donnees.append("action", action);
    donnees.append("reponse_vendeur", "");

    fetch("../backend/repondre_negociation.php", {
        method: "POST",
        body: donnees
    })
        .then(function(reponse) {
            return reponse.json();
        })
        .then(function(resultat) {
            if (resultat.succes === true) {
                chargerNegociationsVendeur();
                chargerNotifications();
                chargerMesAnnonces();
            } else {
                alert(resultat.message);
            }
        })
        .catch(function() {
            alert("erreur lors de la réponse");
        });
}

// contre proposition vendeur
function contreProposerNegociation(idNegociation) {
    const reponse = prompt("entrez votre contre-proposition ou votre message");

    if (reponse === null || reponse.trim() === "") {
        return;
    }

    const donnees = new FormData();
    donnees.append("id_negociation", idNegociation);
    donnees.append("action", "contre_proposer");
    donnees.append("reponse_vendeur", reponse);

    fetch("../backend/repondre_negociation.php", {
        method: "POST",
        body: donnees
    })
        .then(function(reponse) {
            return reponse.json();
        })
        .then(function(resultat) {
            if (resultat.succes === true) {
                chargerNegociationsVendeur();
                chargerNotifications();
                chargerMesAnnonces();
            } else {
                alert(resultat.message);
            }
        })
        .catch(function() {
            alert("erreur lors de la contre-proposition");
        });
}

// classe statut negociation vendeur
function classeStatutNegociationVendeur(statut) {
    if (statut === "acceptee") {
        return "negociation-acceptee";
    }

    if (statut === "refusee") {
        return "negociation-refusee";
    }

    if (statut === "contre_proposition") {
        return "negociation-contre";
    }

    return "negociation-attente";
}

// texte statut negociation vendeur
function formaterStatutNegociationVendeur(statut) {
    if (statut === "acceptee") {
        return "acceptée";
    }

    if (statut === "refusee") {
        return "refusée";
    }

    if (statut === "contre_proposition") {
        return "contre-proposition";
    }

    return "en attente";
}

// affiche le champ marque personnalisee si le vendeur choisit "autre"
function gererMarquePersonnalisee() {
    const selectMarque = document.getElementById("id_marque");
    const blocMarque = document.getElementById("blocMarquePersonnalisee");
    const champMarque = document.getElementById("marque_personnalisee");

    if (!selectMarque || !blocMarque || !champMarque) {
        return;
    }

    afficherChampMarquePersonnalisee();

    selectMarque.addEventListener("change", function() {
        afficherChampMarquePersonnalisee();
    });
}

// affichage marque personnalisee
function afficherChampMarquePersonnalisee() {
    const selectMarque = document.getElementById("id_marque");
    const blocMarque = document.getElementById("blocMarquePersonnalisee");
    const champMarque = document.getElementById("marque_personnalisee");

    if (!selectMarque || !blocMarque || !champMarque) {
        return;
    }

    if (selectMarque.value === "autre") {
        blocMarque.style.display = "block";
        champMarque.required = true;
    } else {
        blocMarque.style.display = "none";
        champMarque.required = false;
        champMarque.value = "";
    }
}

// gere l'apercu des images et le choix de l'image principale
function gererPreviewImagesUpload() {
    const inputImages = document.getElementById("images_voiture");
    const preview = document.getElementById("previewImagesUpload");
    const selectPrincipal = document.getElementById("image_principale_index");

    if (!inputImages || !preview || !selectPrincipal) {
        return;
    }

    inputImages.addEventListener("change", function() {
        preview.innerHTML = "";
        selectPrincipal.innerHTML = "";

        const fichiers = Array.from(inputImages.files);

        if (fichiers.length > 6) {
            alert("vous pouvez importer 6 images maximum");
            inputImages.value = "";
            selectPrincipal.innerHTML = `<option value="0">Image 1</option>`;
            return;
        }

        if (fichiers.length === 0) {
            selectPrincipal.innerHTML = `<option value="0">Image 1</option>`;
            return;
        }

        fichiers.forEach(function(fichier, index) {
            const option = document.createElement("option");
            option.value = index;
            option.textContent = "Image " + (index + 1);

            if (index === 0) {
                option.selected = true;
            }

            selectPrincipal.appendChild(option);

            const lecteur = new FileReader();

            lecteur.onload = function(evenement) {
                const bloc = document.createElement("div");
                bloc.classList.add("image-preview-upload");

                bloc.innerHTML = `
                    <img src="${evenement.target.result}" alt="aperçu image ${index + 1}">
                    <span>Image ${index + 1}</span>
                `;

                preview.appendChild(bloc);
            };

            lecteur.readAsDataURL(fichier);
        });
    });
}
