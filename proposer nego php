<?php
session_start();

require_once "connexion_bdd.php";

header("Content-Type: application/json; charset=utf-8");

// on verifie que l'utilisateur est connecte
if (!isset($_SESSION["id_utilisateur"])) {
    echo json_encode([
        "succes" => false,
        "message" => "utilisateur non connecte"
    ]);
    exit;
}

// seul un acheteur peut proposer une negociation
if ($_SESSION["role"] !== "acheteur") {
    echo json_encode([
        "succes" => false,
        "message" => "seuls les acheteurs peuvent negocier"
    ]);
    exit;
}

// on verifie les donnees
if (!isset($_POST["id_voiture"]) || !isset($_POST["prix_propose"])) {
    echo json_encode([
        "succes" => false,
        "message" => "donnees manquantes"
    ]);
    exit;
}

$id_acheteur = $_SESSION["id_utilisateur"];
$id_voiture = intval($_POST["id_voiture"]);
$prix_propose = floatval($_POST["prix_propose"]);
$message_acheteur = isset($_POST["message_acheteur"]) ? trim($_POST["message_acheteur"]) : "";

// on recupere la voiture
$requete_voiture = "
    SELECT 
        v.id_voiture,
        v.modele,
        v.mode_vente,
        v.statut_annonce,
        v.id_vendeur,
        m.nom_marque
    FROM VOITURE v
    INNER JOIN MARQUE m ON v.id_marque = m.id_marque
    WHERE v.id_voiture = ?
    LIMIT 1
";

$preparation_voiture = mysqli_prepare($connexion, $requete_voiture);
mysqli_stmt_bind_param($preparation_voiture, "i", $id_voiture);
mysqli_stmt_execute($preparation_voiture);

$resultat_voiture = mysqli_stmt_get_result($preparation_voiture);

if (mysqli_num_rows($resultat_voiture) === 0) {
    echo json_encode([
        "succes" => false,
        "message" => "voiture introuvable"
    ]);
    exit;
}

$voiture = mysqli_fetch_assoc($resultat_voiture);

// on verifie que la voiture est negociable
if ($voiture["mode_vente"] !== "negociation" || $voiture["statut_annonce"] !== "validee") {
    echo json_encode([
        "succes" => false,
        "message" => "cette voiture ne peut pas etre negociee"
    ]);
    exit;
}

$id_vendeur = intval($voiture["id_vendeur"]);

// on evite qu'un vendeur negocie sa propre voiture
if ($id_vendeur === intval($id_acheteur)) {
    echo json_encode([
        "succes" => false,
        "message" => "vous ne pouvez pas negocier votre propre annonce"
    ]);
    exit;
}

// on ajoute la negociation
$requete = "
    INSERT INTO NEGOCIATION (
        prix_propose,
        message_acheteur,
        statut_negociation,
        id_acheteur,
        id_vendeur,
        id_voiture
    )
    VALUES (?, ?, 'en_attente', ?, ?, ?)
";

$preparation = mysqli_prepare($connexion, $requete);
mysqli_stmt_bind_param(
    $preparation,
    "dsiii",
    $prix_propose,
    $message_acheteur,
    $id_acheteur,
    $id_vendeur,
    $id_voiture
);

if (!mysqli_stmt_execute($preparation)) {
    echo json_encode([
        "succes" => false,
        "message" => "erreur lors de la negociation"
    ]);
    exit;
}

// notification vendeur
$message = "une nouvelle negociation a ete recue sur votre " . $voiture["nom_marque"] . " " . $voiture["modele"];
$type_notification = "negociation_recue";

$requete_notification = "
    INSERT INTO NOTIFICATION (message, type_notification, lu, id_utilisateur)
    VALUES (?, ?, FALSE, ?)
";

$preparation_notification = mysqli_prepare($connexion, $requete_notification);
mysqli_stmt_bind_param($preparation_notification, "ssi", $message, $type_notification, $id_vendeur);
mysqli_stmt_execute($preparation_notification);

echo json_encode([
    "succes" => true,
    "message" => "negociation envoyee"
]);
?>
