/* adaptation tablette */
@media screen and (max-width: 1150px) {
    .zone-catalogue {
        grid-template-columns: 1fr;
    }

    .filtres {
        position: static;
    }

    .catalogue-grille {
        grid-template-columns: repeat(2, 1fr);
    }
}

/* adaptation petit ecran */
@media screen and (max-width: 950px) {
    .navigation {
        display: none;
    }

    .contenu-hero {
        width: 100%;
    }

    .hero h1 {
        font-size: 42px;
    }

    .grille-voitures,
    .grille-modes,
    .bandeau {
        grid-template-columns: 1fr;
    }

    .pied-page {
        flex-direction: column;
    }
}

/* adaptation telephone */
@media screen and (max-width: 700px) {
    .page-catalogue {
        padding: 120px 6% 70px;
    }

    .titre-page h1 {
        font-size: 36px;
    }

    .catalogue-grille {
        grid-template-columns: 1fr;
    }

    .barre-resultats {
        flex-direction: column;
        align-items: start;
    }
}

