
<?php
session_start();

require_once "connexion_bdd.php";

header("Content-Type: application/json; charset=utf-8");

mysqli_report(MYSQLI_REPORT_ERROR | MYSQLI_REPORT_STRICT);

try {
    // on verifie la connexion
    if (!isset($_SESSION["id_utilisateur"])) {
        echo json_encode([
            "succes" => false,
            "message" => "utilisateur non connecte"
        ]);
        exit;
    }

    // seul un acheteur peut repondre
    if ($_SESSION["role"] !== "acheteur") {
        echo json_encode([
            "succes" => false,
            "message" => "acces refuse"
        ]);
        exit;
    }

    // on verifie les donnees envoyees
    if (!isset($_POST["id_negociation"]) || !isset($_POST["action"])) {
        echo json_encode([
            "succes" => false,
            "message" => "donnees manquantes"
        ]);
        exit;
    }

    $id_acheteur = intval($_SESSION["id_utilisateur"]);
    $id_negociation = intval($_POST["id_negociation"]);
    $action = $_POST["action"];

    $nouveau_prix = isset($_POST["nouveau_prix"]) ? floatval($_POST["nouveau_prix"]) : 0;
    $message_acheteur = isset($_POST["message_acheteur"]) ? trim($_POST["message_acheteur"]) : "";

    // on recupere la negociation + voiture
    $requete_infos = "
        SELECT 
            n.id_negociation,
            n.id_acheteur,
            n.id_vendeur,
            n.id_voiture,
            n.prix_propose,
            n.statut_negociation,
            v.modele,
            v.statut_annonce,
            m.nom_marque
        FROM NEGOCIATION n
        INNER JOIN VOITURE v ON n.id_voiture = v.id_voiture
        INNER JOIN MARQUE m ON v.id_marque = m.id_marque
        WHERE n.id_negociation = ?
        AND n.id_acheteur = ?
        LIMIT 1
    ";

    $preparation_infos = mysqli_prepare($connexion, $requete_infos);
    mysqli_stmt_bind_param($preparation_infos, "ii", $id_negociation, $id_acheteur);
    mysqli_stmt_execute($preparation_infos);

    $resultat_infos = mysqli_stmt_get_result($preparation_infos);

    if (mysqli_num_rows($resultat_infos) === 0) {
        echo json_encode([
            "succes" => false,
            "message" => "negociation introuvable"
        ]);
        exit;
    }

    $negociation = mysqli_fetch_assoc($resultat_infos);

    $id_vendeur = intval($negociation["id_vendeur"]);
    $id_voiture = intval($negociation["id_voiture"]);

    // on ne peut repondre que sur une contre proposition
    if ($negociation["statut_negociation"] !== "contre_proposition") {
        echo json_encode([
            "succes" => false,
            "message" => "cette negociation ne peut pas etre modifiee"
        ]);
        exit;
    }

    // si la voiture est deja vendue, on bloque
    if ($negociation["statut_annonce"] === "vendue") {
        echo json_encode([
            "succes" => false,
            "message" => "ce vehicule est deja vendu"
        ]);
        exit;
    }

    mysqli_begin_transaction($connexion);

    // cas 1 : l'acheteur accepte la contre proposition
    if ($action === "accepter") {

        // on accepte la negociation
        $requete_accepter = "
            UPDATE NEGOCIATION
            SET 
                statut_negociation = 'acceptee',
                date_reponse = NOW()
            WHERE id_negociation = ?
            AND id_acheteur = ?
        ";

        $preparation_accepter = mysqli_prepare($connexion, $requete_accepter);
        mysqli_stmt_bind_param($preparation_accepter, "ii", $id_negociation, $id_acheteur);
        mysqli_stmt_execute($preparation_accepter);

        // on met la voiture en vendue
        $requete_voiture = "
            UPDATE VOITURE
            SET statut_annonce = 'vendue'
            WHERE id_voiture = ?
        ";

        $preparation_voiture = mysqli_prepare($connexion, $requete_voiture);
        mysqli_stmt_bind_param($preparation_voiture, "i", $id_voiture);
        mysqli_stmt_execute($preparation_voiture);

        // on refuse automatiquement les autres negociations de cette voiture
        $requete_autres_negociations = "
            UPDATE NEGOCIATION
            SET 
                statut_negociation = 'refusee',
                reponse_vendeur = 'le vehicule a ete vendu',
                date_reponse = NOW()
            WHERE id_voiture = ?
            AND id_negociation != ?
            AND statut_negociation != 'acceptee'
        ";

        $preparation_autres = mysqli_prepare($connexion, $requete_autres_negociations);
        mysqli_stmt_bind_param($preparation_autres, "ii", $id_voiture, $id_negociation);
        mysqli_stmt_execute($preparation_autres);

        // notification vendeur
        $message_notification = "l'acheteur a accepte votre contre-proposition sur " . $negociation["nom_marque"] . " " . $negociation["modele"] . ". Le vehicule est maintenant vendu.";
        $type_notification = "negociation_acceptee";
    }

    // cas 2 : l'acheteur refait une offre
    elseif ($action === "contre_proposer") {

        if ($nouveau_prix <= 0) {
            mysqli_rollback($connexion);

            echo json_encode([
                "succes" => false,
                "message" => "prix invalide"
            ]);
            exit;
        }

        $requete_contre = "
            UPDATE NEGOCIATION
            SET 
                prix_propose = ?,
                message_acheteur = ?,
                reponse_vendeur = NULL,
                statut_negociation = 'en_attente',
                date_negociation = NOW(),
                date_reponse = NULL
            WHERE id_negociation = ?
            AND id_acheteur = ?
        ";

        $preparation_contre = mysqli_prepare($connexion, $requete_contre);
        mysqli_stmt_bind_param(
            $preparation_contre,
            "dsii",
            $nouveau_prix,
            $message_acheteur,
            $id_negociation,
            $id_acheteur
        );
        mysqli_stmt_execute($preparation_contre);

        // notification vendeur
        $message_notification = "l'acheteur a envoye une nouvelle offre sur " . $negociation["nom_marque"] . " " . $negociation["modele"];
        $type_notification = "negociation_recue";
    }

    else {
        mysqli_rollback($connexion);

        echo json_encode([
            "succes" => false,
            "message" => "action invalide"
        ]);
        exit;
    }

    // creation notification vendeur
    $requete_notification = "
        INSERT INTO NOTIFICATION (message, type_notification, lu, id_utilisateur)
        VALUES (?, ?, FALSE, ?)
    ";

    $preparation_notification = mysqli_prepare($connexion, $requete_notification);
    mysqli_stmt_bind_param(
        $preparation_notification,
        "ssi",
        $message_notification,
        $type_notification,
        $id_vendeur
    );
    mysqli_stmt_execute($preparation_notification);

    mysqli_commit($connexion);

    echo json_encode([
        "succes" => true,
        "message" => "reponse envoyee"
    ]);
    exit;

} catch (Throwable $erreur) {
    mysqli_rollback($connexion);

    echo json_encode([
        "succes" => false,
        "message" => "erreur : " . $erreur->getMessage()
    ]);
    exit;
}
?>
